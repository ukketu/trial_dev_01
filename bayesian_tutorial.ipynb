{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Empirical Bayes Tutorial\n",
    "\n",
    "This notebook demonstrates empirical Bayes (experience Bayes) for estimating binomial proportions using a Beta prior.\n",
    "We'll simulate data from multiple groups, estimate a prior from the data (empirical Bayes), then compute posterior estimates.\n"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "import numpy as np\n",
    "import scipy.stats as stats\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "%matplotlib inline\n",
    "sns.set_style('whitegrid')\n"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# Simulate true proportions for 20 groups from a Beta(2,5) distribution\n",
    "np.random.seed(42)\n",
    "n_groups = 20\n",
    "true_props = np.random.beta(2, 5, n_groups)\n",
    "\n",
    "# For each group, observe n=25 trials\n",
    "n_trials = 25\n",
    "counts = np.random.binomial(n_trials, true_props)\n",
    "\n",
    "print('True proportions:', np.round(true_props, 3))\n",
    "Observed counts:', counts)\n",
    "Observed frequencies:', np.round(counts / n_trials, 3)\n"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# Empirical Bayes: estimate prior parameters from the data using method of moments\n",
    "# For Beta prior, mean = a/(a+b), variance = ab/[(a+b)^2 (a+b+1)]\n",
    "observed_freq = counts / n_trials\n",
    "mean_obs = observed_freq.mean()\n",
    "var_obs = observed_freq.var(ddof=1)\n",
    "\n",
    "# Solve for a,b\n",
    "# Let m = mean_obs, v = var_obs\n",
    "# a = m * ( (m*(1-m) / v) - 1 )\n",
    "# b = (1-m) * ( (m*(1-m) / v) - 1 )\n",
    "ratio = mean_obs * (1 - mean_obs) / var_obs\n",
    "a_est = mean_obs * (ratio - 1)\n",
    "b_est = (1 - mean_obs) * (ratio - 1)\n",
    "\n",
    print(f'Estimated prior: alpha = {a_est:.2f}, beta = {b_est:.2f}')\n"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# Compute posterior parameters for each group: posterior Beta(alpha + successes, beta + failures)\n",
    "post_alpha = a_est + counts\n",
    "post_beta = b_est + (n_trials - counts)\n",
    "\n",
    "# Posterior mean (EB estimate)\n",
    "eb_estimates = post_alpha / (post_alpha + post_beta)\n",
    "\n",
    "# Compare with MLE (observed frequency) and true values\n",
    "comparison = np.column_stack((true_props, observed_freq, eb_estimates))\n",
    "print('Group | True | MLE | EB')\n",
    "for i in range(n_groups):\n",
    "    print(f'{i+1:2d} | {true_props[i]:.3f} | {observed_freq[i]:.3f} | {eb_estimates[i]:.3f}')\n"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# Plot shrinkage effect\n",
    "plt.figure(figsize=(10,6))\n",
    "x = np.sort(true_props)\n",
    "plt.plot(x, x, 'k--', label='Ideal')\n",
    "plt.scatter(observed_freq, eb_estimates, color='red', label='EB estimates', zorder=5)\n",
    "plt.scatter(observed_freq, observed_freq, color='blue', label='MLE (observed)', alpha=0.7, zorder=5)\n",
    "plt.xlabel('Observed frequency (MLE)')\n",
    "plt.ylabel('Empirical Bayes estimate')\n",
    "plt.title('Shrinkage towards prior mean')\n",
    "plt.legend()\n",
    "plt.grid(True)\n",
    "plt.show()\n"
   ],
   "execution_count": null,
   "outputs": []
  }
